<view class="settings-container">
  <!-- 功能设置 -->
  <view class="setting-section">
    <view class="section-title">⚙️ 功能设置</view>

    <view class="setting-item" bindtap="goToContactSettings">
      <view class="setting-info">
        <view class="setting-label">联系方式</view>
        <view class="setting-desc">设置微信二维码</view>
      </view>
      <view class="setting-arrow">></view>
    </view>

    <view class="setting-item">
      <view class="setting-info">
        <view class="setting-label">消息通知</view>
        <view class="setting-desc">接收评论和系统消息</view>
      </view>
      <switch checked="{{notificationEnabled}}" bindchange="onNotificationChange" />
    </view>

    <view class="setting-item" bindtap="viewLocationSetting">
      <view class="setting-info">
        <view class="setting-label">位置权限</view>
        <view class="setting-desc">{{locationStatus ? '已授权位置权限' : '未授权位置权限'}}</view>
      </view>
      <view class="setting-arrow">></view>
    </view>
  </view>

  <!-- 帮助与支持 -->
  <view class="setting-section">
    <view class="section-title">📚 帮助与支持</view>
    
    <view class="setting-item" bindtap="viewAgreement">
      <view class="setting-info">
        <view class="setting-label">用户协议</view>
        <view class="setting-desc">使用条款和规则</view>
      </view>
      <view class="setting-arrow">></view>
    </view>
    
    <view class="setting-item" bindtap="viewPolicy">
      <view class="setting-info">
        <view class="setting-label">隐私政策</view>
        <view class="setting-desc">数据使用和保护说明</view>
      </view>
      <view class="setting-arrow">></view>
    </view>
    
    <view class="setting-item" bindtap="viewRules">
      <view class="setting-info">
        <view class="setting-label">平台规则</view>
        <view class="setting-desc">发布和交易规范</view>
      </view>
      <view class="setting-arrow">></view>
    </view>
    
    <view class="setting-item" bindtap="contactService">
      <view class="setting-info">
        <view class="setting-label">联系客服</view>
        <view class="setting-desc">问题反馈和意见建议</view>
      </view>
      <view class="setting-arrow">></view>
    </view>
  </view>

  <!-- 关于 -->
  <view class="setting-section">
    <view class="section-title">ℹ️ 关于</view>
    
    <view class="setting-item">
      <view class="setting-info">
        <view class="setting-label">版本号</view>
        <view class="setting-desc">当前版本 1.0.0</view>
      </view>
    </view>
    
    <view class="setting-item" bindtap="clearCache">
      <view class="setting-info">
        <view class="setting-label">清理缓存</view>
        <view class="setting-desc">清理本地缓存数据</view>
      </view>
      <view class="setting-arrow">></view>
    </view>
  </view>

  <!-- 重置功能 -->
  <view class="reset-section">
    <button class="reset-btn" bindtap="resetAgreement">
      重置用户协议
    </button>
    <view class="reset-desc">将重新显示用户授权页面</view>
  </view>
</view>