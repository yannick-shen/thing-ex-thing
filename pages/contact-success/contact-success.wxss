.container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: calc(env(safe-area-inset-bottom) + 180rpx);
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.loading-text {
  font-size: 30rpx;
  color: #999;
}

/* 成功页面 */
.success-content {
  padding: 0;
}

/* 顶部祝贺 */
.header {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  padding: 60rpx 30rpx;
  text-align: center;
  color: white;
}

.success-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 物品信息卡片 */
.item-card {
  background: white;
  margin: -30rpx 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
  position: relative;
}

.item-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.item-info {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.info-item {
  display: flex;
  margin-bottom: 12rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  width: 100rpx;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

/* 二维码区域 */
.qr-section {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.qr-code-wrapper {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.qr-code {
  width: 500rpx;
  height: 500rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.qr-error {
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 操作步骤 */
.steps-section {
  background: white;
  margin: 0 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
}

.steps-list {
  margin-top: 10rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 25rpx;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-number {
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.step-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  padding-top: 6rpx;
}

/* 温馨提示 */
.tips-section {
  background: #fff7e6;
  margin: 0 30rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  border-left: 6rpx solid #faad14;
}

.tips-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #faad14;
  margin-bottom: 15rpx;
}

.tips-list {
  margin-top: 10rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #d48806;
  line-height: 1.6;
  margin-bottom: 10rpx;
  padding-left: 20rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

/* 底部按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  display: flex;
  gap: 20rpx;
}

.btn-save {
  flex: 2;
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-save::after {
  border: none;
}

.btn-back {
  flex: 1;
  background: white;
  color: #666;
  border: 2rpx solid #d9d9d9;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
}

.btn-back::after {
  border: none;
}
