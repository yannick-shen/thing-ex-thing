.publish-container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 登录提示样式 */
.login-required {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 0 40rpx;
}

.login-prompt {
  text-align: center;
  background: white;
  border-radius: 20rpx;
  padding: 80rpx 60rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  width: 100%;
  max-width: 600rpx;
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 60rpx;
  line-height: 1.5;
}

.login-btn {
  background: #1677ff;
  color: white;
  border: none;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  width: 100%;
}

.login-btn::after {
  border: none;
}

.skip-btn {
  background: transparent;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 84rpx;
  font-size: 28rpx;
  width: 100%;
}

.skip-btn::after {
  border: none;
}

/* 表单容器 */
.form-container {
  background: white;
  padding: 40rpx 20rpx;
  max-width: 750rpx;
  margin: 0 auto;
}

/* 表单区块 */
.form-section {
  margin-bottom: 50rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.required-star {
  color: #ff4757;
  margin-left: 5rpx;
}

.upload-tips {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
  margin-left: 10rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 30rpx;
}

.form-item.required .label::after {
  content: '*';
  color: #ff4757;
  margin-left: 5rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
}

.location-tips {
  font-size: 24rpx;
  color: #667eea;
  margin-left: auto;
}

/* 输入框样式 */
.input-field {
  width: 100%;
  padding: 30rpx 25rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #333333 !important;
  background: #fafafa;
  box-sizing: border-box;
  line-height: 1.4;
  text-align: left;
  vertical-align: middle;
  outline: none;
  height: auto;
  min-height: 80rpx;
  display: block;
}

.textarea-field {
  width: 100%;
  padding: 30rpx 25rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  background: #fafafa;
  box-sizing: border-box;
  line-height: 1.5;
  min-height: 300rpx;
  max-height: 600rpx;
  overflow-y: auto;
  text-align: left;
  vertical-align: top;
}

.input-field:focus, .textarea-field:focus {
  border-color: #667eea;
  background: white;
  color: #333333 !important;
}

.input-counter {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

/* Placeholder样式优化 */
.input-placeholder {
  color: #999 !important;
  text-align: left;
}

.textarea-placeholder {
  color: #999 !important;
  text-align: left;
}

/* 交易形态选择 */
.mode-group, .trade-group {
  display: flex;
  gap: 20rpx;
}

.mode-item, .trade-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 25rpx 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  background: #fafafa;
  transition: all 0.3s;
}

.mode-item.active, .trade-item.active {
  border-color: #667eea;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
}

.mode-item radio, .trade-item radio {
  display: none;
}

.mode-icon, .trade-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.mode-text, .trade-text {
  font-size: 26rpx;
  color: #333;
}

.mode-item.active .mode-text,
.trade-item.active .trade-text {
  color: #667eea;
  font-weight: 500;
}

/* 位置选择器 */
.location-selector {
  display: flex;
  align-items: center;
  padding: 25rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  background: #fafafa;
}

.location-info {
  flex: 1;
}

.location-detail {
  
}

.location-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 5rpx;
}

.location-address {
  font-size: 24rpx;
  color: #666;
}

.location-placeholder {
  font-size: 28rpx;
  color: #999;
}

.location-arrow {
  font-size: 32rpx;
  color: #999;
  margin-left: 20rpx;
}

/* 位置警告样式（方案C） */
.warning-icon {
  color: #ffa502;
  margin-left: 10rpx;
  font-size: 28rpx;
}

.location-warning-text {
  font-size: 24rpx;
  color: #ffa502;
  margin-top: 15rpx;
  padding: 20rpx;
  background: rgba(255, 165, 2, 0.1);
  border-radius: 8rpx;
  border-left: 4rpx solid #ffa502;
  line-height: 1.5;
}





/* 图片上传 */
.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.uploaded {
  position: relative;
}

.uploaded-image {
  width: 100%;
  height: 100%;
}

.image-actions {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-delete {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #333;
  position: absolute;
  top: 10rpx;
  right: 10rpx;
}

.image-cover-tag {
  position: absolute;
  bottom: 10rpx;
  left: 10rpx;
  background: #667eea;
  color: white;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.add {
  border: 2rpx dashed #ddd;
  background: #fafafa;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 60rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.add-text {
  font-size: 24rpx;
  color: #999;
}

/* 提交区域 */
.submit-section {
  margin-top: 60rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.button-row {
  display: flex;
  gap: 20rpx;
}

.button-row button {
  width: 260rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  margin-bottom: 20rpx;
}

.submit-btn.submitting {
  opacity: 0.7;
}

.submit-btn[disabled] {
  opacity: 0.7;
}

.edit-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.secondary-btn {
  flex: 1;
  height: 88rpx;
  background: #1677ff;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
}

.secondary-btn[disabled] {
  opacity: 0.7;
}

.draft-btn {
  width: 100%;
  height: 88rpx;
  background: #f0f0f0;
  color: #333;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  margin-bottom: 20rpx;
}

.draft-btn[disabled] {
  opacity: 0.7;
}

.submit-tips {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 位置说明弹窗 */
.tips-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.tips-content {
  width: 80%;
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
}

.tips-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 30rpx;
  text-align: left;
}

.tips-close {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 20rpx 40rpx;
  border-radius: 25rpx;
  font-size: 28rpx;
}