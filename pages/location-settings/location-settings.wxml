<view class="settings-container">
  <!-- 位置权限设置项 -->
  <view class="setting-section">
    <view class="setting-item" bindtap="openSetting">
      <view class="setting-info">
        <view class="setting-label">位置权限</view>
        <view class="setting-desc">{{locationStatus.authorized ? '已授权' : '未授权'}}</view>
      </view>
      <view class="setting-arrow">></view>
    </view>
  </view>

  <!-- 权限说明 -->
  <view class="info-card">
    <view class="card-title">📍 位置权限说明</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">用途：</text>
        <text class="info-content">展示附近的闲置物品，设置发布物品位置</text>
      </view>

      <view class="info-item">
        <text class="info-label">权限类型：</text>
        <text class="info-content">仅在使用时获取，不会后台定位</text>
      </view>
    </view>
  </view>
</view>
