<view class="settings-container">
  <!-- 顶部导航 -->
  <view class="header">
    <view class="nav-bar">
      <view class="nav-back" bindtap="goBack">‹</view>
      <view class="nav-title">位置权限设置</view>
      <view class="nav-placeholder"></view>
    </view>
  </view>

  <!-- 权限状态 -->
  <view class="status-card">
    <view class="status-header">
      <view class="status-icon {{locationStatus.authorized ? 'authorized' : locationStatus.denied ? 'denied' : 'never'}}">
        {{locationStatus.authorized ? '✓' : locationStatus.denied ? '✗' : '?'}}
      </view>
      <view class="status-info">
        <view class="status-title">{{locationStatus.authorized ? '已授权位置' : locationStatus.denied ? '已拒绝位置' : '未设置位置'}}</view>
        <view class="status-desc">{{locationStatus.authorized ? '小程序可以获取您的位置信息' : locationStatus.denied ? '小程序无法获取您的位置信息' : '小程序尚未请求位置权限'}}</view>
      </view>
    </view>
  </view>

  <!-- 位置权限说明 -->
  <view class="info-card">
    <view class="card-title">📍 位置权限说明</view>
    <view class="info-list">
      <view class="info-item">
        <text class="info-label">用途：</text>
        <text class="info-content">展示附近的闲置物品，设置发布物品位置</text>
      </view>
      <view class="info-item">
        <text class="info-label">隐私保护：</text>
        <text class="info-content">位置信息会进行模糊处理，不会显示精确位置</text>
      </view>
      <view class="info-item">
        <text class="info-label">权限类型：</text>
        <text class="info-content">仅在使用时获取，不会后台定位</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <view wx:if="{{locationStatus.authorized}}" class="action-group">
      <button class="action-btn primary" bindtap="testLocation">测试位置获取</button>
      <button class="action-btn secondary" bindtap="revokeLocation">撤销授权</button>
    </view>
    
    <view wx:if="{{locationStatus.denied}}" class="action-group">
      <button class="action-btn primary" bindtap="grantLocation">开启位置权限</button>
      <button class="action-btn secondary" bindtap="showGuide">查看设置指南</button>
    </view>
    
    <view wx:if="{{locationStatus.neverAsked}}" class="action-group">
      <button class="action-btn primary" bindtap="requestLocation">申请位置权限</button>
    </view>
  </view>

  <!-- 当前位置信息 -->
  <view wx:if="{{currentLocation}}" class="location-info-card">
    <view class="card-title">📍 当前位置信息</view>
    <view class="location-detail">
      <view class="location-row">
        <text class="location-label">经度：</text>
        <text class="location-value">{{currentLocation.longitude}}</text>
      </view>
      <view class="location-row">
        <text class="location-label">纬度：</text>
        <text class="location-value">{{currentLocation.latitude}}</text>
      </view>
      <view class="location-row">
        <text class="location-label">更新时间：</text>
        <text class="location-value">{{locationUpdateTime}}</text>
      </view>
    </view>
    <button class="refresh-btn" bindtap="refreshLocation">刷新位置</button>
  </view>

  <!-- 设置指南 -->
  <view wx:if="{{showGuide}}" class="guide-modal">
    <view class="guide-content">
      <view class="guide-title">如何开启位置权限</view>
      <view class="guide-steps">
        <view class="guide-step">
          <text class="step-number">1</text>
          <text class="step-text">点击右上角"..."菜单</text>
        </view>
        <view class="guide-step">
          <text class="step-number">2</text>
          <text class="step-text">选择"设置"</text>
        </view>
        <view class="guide-step">
          <text class="step-number">3</text>
          <text class="step-text">找到"位置信息"，设置为"使用时允许"</text>
        </view>
        <view class="guide-step">
          <text class="step-number">4</text>
          <text class="step-text">返回小程序即可使用位置功能</text>
        </view>
      </view>
      <button class="guide-close" bindtap="hideGuide">知道了</button>
    </view>
  </view>
</view>