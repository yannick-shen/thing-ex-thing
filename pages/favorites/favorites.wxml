<view class="container">
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="login-required">
    <view class="card login-prompt">
      <view class="login-icon">❤️</view>
      <text class="text-title">需要登录才能查看收藏</text>
      <text class="text-body">登录后可以查看收藏的物品</text>
      <button class="btn-primary" bindtap="goToLogin">立即登录</button>
    </view>
  </view>

  <!-- 已登录状态或跳过登录状态 -->
  <view wx:else>
    <view class="list">
      <view 
        wx:for="{{items}}" 
        wx:key="_id" 
        wx:for-index="index"
        class="slide-item"
      >
        <!-- 滑动内容区 -->
        <view 
          class="card-item {{item.isSliding ? 'sliding' : ''}}" 
          bindtap="goDetail" 
          data-id="{{item._id}}"
          bindtouchstart="onTouchStart"
          bindtouchmove="onTouchMove"
          bindtouchend="onTouchEnd"
          data-index="{{index}}"
        >
          <image
            src="{{item.images && item.images.length > 0 ? item.images[0] : '/assets/images/placeholder-empty.png'}}"
            mode="aspectFill"
            class="item-img"
            binderror="onImageError"
            data-index="{{index}}"
          />
          <view class="item-info flex-column gap-sm">
            <text class="text-title">{{item.title}}</text>
            <text class="text-muted">{{item.desc}}</text>
            <view class="item-price">
              <text wx:if="{{item.mode === 'sale'}}" class="text-title">¥{{item.price}}</text>
              <text wx:else class="text-body">{{item.mode === 'exchange' ? '交换' : '赠送'}}</text>
            </view>
          </view>
        </view>
        <!-- 删除按钮 -->
        <view 
          class="delete-btn {{item.isSliding ? 'show' : ''}}" 
          catchtap="deleteFavorite" 
          data-id="{{item._id}}"
          data-index="{{index}}"
        >删除</view>
      </view>
    </view>

    <view wx:if="{{items.length === 0}}" class="empty">暂无收藏</view>
  </view>
</view>