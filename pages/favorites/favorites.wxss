/* 登录提示 */
.login-required { display: flex; align-items: center; justify-content: center; min-height: 60vh; }
.login-prompt { width: 80%; text-align: center; padding: 24px; }
.login-icon { font-size: 48px; margin-bottom: 12px; }

/* 列表项 */
.item-img { width: 80px; height: 80px; border-radius: 8px; margin-right: 12px; }
.item-info { flex: 1; }
.item-price { margin-top: 4px; }
.item-price text { font-size: 16px; font-weight: 600; color: #ff4d4f; }

/* 空状态 */
.empty { text-align: center; padding: 40px 20px; color: #999; font-size: 14px; }
