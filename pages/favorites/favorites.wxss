/* 登录提示 */
.login-required { display: flex; align-items: center; justify-content: center; min-height: 60vh; }
.login-prompt { width: 80%; text-align: center; padding: 24px; }
.login-icon { font-size: 48px; margin-bottom: 12px; }

/* 滑动容器 */
.slide-item { position: relative; overflow: hidden; margin-bottom: 10px; }

/* 列表项 */
.card-item { 
  display: flex; 
  padding: 12px; 
  background: #fff; 
  border-radius: 8px;
  transition: transform 0.2s ease;
}
.card-item.sliding { transform: translateX(-60px); }
.item-img { width: 80px; height: 80px; border-radius: 8px; margin-right: 12px; }
.item-info { flex: 1; }
.item-price { margin-top: 4px; }
.item-price text { font-size: 16px; font-weight: 600; color: #ff4d4f; }

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 60px;
  background: #ff4d4f;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  transform: translateX(100%);
  transition: transform 0.2s ease;
  border-radius: 8px;
}
.delete-btn.show { transform: translateX(0); }

/* 空状态 */
.empty { text-align: center; padding: 40px 20px; color: #999; font-size: 14px; }
