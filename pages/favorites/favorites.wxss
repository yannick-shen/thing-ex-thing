.container{background:#f7f8fa;min-height:100vh;padding:12px}

/* 登录提示样式 */
.login-required {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 0 40rpx;
}

.login-prompt {
  text-align: center;
  background: white;
  border-radius: 20rpx;
  padding: 80rpx 60rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  width: 100%;
  max-width: 600rpx;
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 60rpx;
  line-height: 1.5;
}

.login-btn {
  background: #1677ff;
  color: white;
  border: none;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  width: 100%;
}

.login-btn::after {
  border: none;
}

.skip-btn {
  background: transparent;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 50rpx;
  height: 88rpx;
  line-height: 84rpx;
  font-size: 28rpx;
  width: 100%;
}

.skip-btn::after {
  border: none;
}
.list{}
.item-card{background:#fff;border-radius:8px;margin-bottom:12px;padding:12px;display:flex;gap:12px}
.item-img{width:80px;height:80px;border-radius:8px;background:#f2f2f2;flex-shrink:0}
.item-info{flex:1;min-width:0;display:flex;flex-direction:column;justify-content:space-between}
.item-title{font-size:15px;font-weight:600;margin-bottom:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.item-desc{font-size:12px;color:#999;margin-bottom:8px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.item-price{}
.price{font-size:16px;color:#ff4d4f;font-weight:600}
.empty{padding:60px 20px;text-align:center;color:#999}