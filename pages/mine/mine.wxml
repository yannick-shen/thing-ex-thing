<view class="mine-container">

  <!-- 物品分类标签 -->
  <view class="tab-section fixed">
    <view class="tab-group flex-row">
      <view
        class="tab-item {{currentTab === 'active' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="active"
      >
        <text class="tab-text">展示中</text>
        <view wx:if="{{stats.active > 0}}" class="tab-count">{{stats.active}}</view>
      </view>
      <view
        class="tab-item {{currentTab === 'draft' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="draft"
      >
        <text class="tab-text">草稿箱</text>
        <view wx:if="{{stats.draft > 0}}" class="tab-count">{{stats.draft}}</view>
      </view>
    </view>
  </view>

  <!-- 物品列表 -->
  <view class="items-list">
    <!-- 空状态 -->
    <view wx:if="{{items.length === 0 && !loading}}" class="empty-state">
      <view class="empty-icon">
        <text wx:if="{{currentTab === 'active'}}">🛍️</text>
        <text wx:if="{{currentTab === 'draft'}}">📝</text>
        <text wx:if="{{currentTab === 'all'}}">📦</text>
      </view>
      <view class="empty-text">
        <view wx:if="{{currentTab === 'active'}}">暂无展示中的物品</view>
        <view wx:if="{{currentTab === 'draft'}}">草稿箱空空如也</view>
        <view wx:if="{{currentTab === 'all'}}">还没有发布任何物品</view>
      </view>
      <view class="empty-desc">
        <view wx:if="{{currentTab === 'active'}}">上架中的物品会在这里显示</view>
        <view wx:if="{{currentTab === 'draft'}}">保存的草稿和到期下架的物品</view>
        <view wx:if="{{currentTab === 'all'}}">点击上方按钮开始发布</view>
      </view>
      <button class="btn-primary" bindtap="goPublish" wx:if="{{currentTab === 'all' || currentTab === 'draft'}}">
        <text wx:if="{{currentTab === 'all'}}">立即发布</text>
        <text wx:if="{{currentTab === 'draft'}}">继续发布</text>
      </button>
      </view>

    <!-- 物品项 -->
    <view
      class="card"
      wx:for="{{items}}"
      wx:key="id"
      bindtap="goDetail"
      data-id="{{item.id}}"
      data-status="{{item.status}}"
    >
      <view class="item-image">
        <image
          src="{{item.images && item.images.length > 0 ? item.images[0] : '/assets/images/placeholder-empty.png'}}"
          mode="aspectFill"
        />
      </view>
      <view class="item-content flex-column gap-sm">
        <text class="text-title">{{item.title}}</text>
        <text class="text-muted">{{item.desc}}</text>
        <view class="flex-between">
          <view class="item-mode mode-{{item.mode}}">
            <text wx:if="{{item.mode === 'sale'}}">¥{{item.price}}</text>
            <text wx:if="{{item.mode === 'exchange'}}">交换</text>
            <text wx:if="{{item.mode === 'donate'}}">赠送</text>
          </view>
          <text class="text-muted">{{item.formattedTime}}</text>
        </view>
        <view class="flex-row gap-md">
          <text class="text-small">👁 {{item.counters.views}}</text>
          <text class="text-small">❤️ {{item.counters.favorites}}</text>
          <text class="text-small">💬 {{item.counters.comments}}</text>
          <view wx:if="{{item.status === 'draft' || item.status === 'off'}}" class="flex-row gap-sm">
            <view class="btn-small btn-danger" catchtap="deleteItem" data-id="{{item.id}}">删除</view>
            <view class="btn-small btn-primary" catchtap="publishDraft" data-id="{{item.id}}">发布</view>
          </view>
          <view wx:else class="btn-small btn-danger" catchtap="deleteItem" data-id="{{item.id}}">
            <text>删除</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-icon">⏳</view>
    <view class="loading-text">加载中...</view>
  </view>
</view>
</view>