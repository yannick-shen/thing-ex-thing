.mine-container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部个人信息 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  color: white;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  margin-right: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder {
  font-size: 60rpx;
}

.user-details {
  flex: 1;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 统计信息 */
.stats {
  display: flex;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 30rpx;
  backdrop-filter: blur(10rpx);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 功能入口 */
.feature-section {
  margin: 20rpx 30rpx;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 25rpx;
}

.feature-icon.publish {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
}

.feature-icon.favorites {
  background: linear-gradient(135deg, #ff4757 0%, #ff6b7a 100%);
}

.feature-icon.messages {
  background: linear-gradient(135deg, #ffa502 0%, #ffb142 100%);
}

.feature-info {
  flex: 1;
}

.feature-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 5rpx;
}

.feature-desc {
  font-size: 26rpx;
  color: #666;
}

.feature-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.message-badge {
  position: absolute;
  top: 30rpx;
  right: 50rpx;
  background: #ff4757;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 30rpx;
  text-align: center;
}

/* 我的物品列表 */
.items-section {
  margin: 20rpx 30rpx;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.section-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.tab-group {
  display: flex;
  background: #f8f9fa;
  border-radius: 25rpx;
  padding: 4rpx;
}

.tab-item {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: white;
  color: #667eea;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.2);
}

/* 物品列表 */
.items-list {
  min-height: 400rpx;
}

/* 空状态 */
.empty-state {
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 25rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

/* 物品卡片 */
.item-card {
  display: flex;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.item-card:last-child {
  border-bottom: none;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 20rpx;
  position: relative;
}

.item-image image {
  width: 100%;
  height: 100%;
}

.status-tag {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  color: white;
}

.status-tag.expired {
  background: rgba(0, 0, 0, 0.6);
}

.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.item-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.item-mode {
  font-size: 24rpx;
  font-weight: 500;
}

.item-mode.mode-sale {
  color: #ff4757;
}

.item-mode.mode-exchange {
  color: #ffa502;
}

.item-mode.mode-donate {
  color: #52c41a;
}

.item-location {
  font-size: 22rpx;
  color: #999;
}

.item-stats {
  display: flex;
  gap: 20rpx;
}

.stat {
  font-size: 22rpx;
  color: #999;
}

/* 操作按钮 */
.item-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.action-btn {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  text-align: center;
  min-width: 60rpx;
}

.action-btn.edit {
  background: #e8f4ff;
  color: #1890ff;
}

.action-btn.republish {
  background: #f0f9ff;
  color: #00b96b;
}

.action-btn.delete {
  background: #fff2f0;
  color: #ff4d4f;
}

/* 加载状态 */
.loading-state {
  padding: 60rpx;
  text-align: center;
}

.loading-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}