/* Tab 分段 */
.tab-section.fixed { position: sticky; top: 0; background: #f7f8fa; z-index: 1; padding: 12px 16px 8px; }
.tab-group { gap: 12px; }
.tab-item { position: relative; padding: 8px 16px; font-size: 14px; color: #666; }
.tab-item.active { color: #1677ff; font-weight: 600; }
.tab-item.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 20px; height: 3px; background: #1677ff; border-radius: 2px; }
.tab-text { position: relative; z-index: 1; }
.tab-count { position: absolute; top: 2px; right: 0; min-width: 16px; height: 16px; background: #ff4d4f; color: #fff; border-radius: 8px; font-size: 10px; display: flex; align-items: center; justify-content: center; padding: 0 4px; }

/* 列表容器 */
.items-list { padding: 8px 16px; }

/* 空状态 */
.empty-state { text-align: center; padding: 60px 20px; }
.empty-icon { font-size: 64px; margin-bottom: 12px; }
.empty-text { font-size: 16px; color: #333; margin-bottom: 8px; }
.empty-desc { font-size: 14px; color: #999; margin-bottom: 24px; }

/* 物品卡片 */
.card { margin-bottom: 12px; display: flex; }
.item-image { width: 90px; height: 90px; margin-right: 12px; flex-shrink: 0; }
.item-image image { width: 100%; height: 100%; border-radius: 8px; }
.item-content { flex: 1; min-width: 0; }
.item-desc { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-mode { font-size: 16px; font-weight: 600; }
.item-mode.mode-sale { color: #FF4757; }
.item-mode.mode-exchange { color: #3742FA; }
.item-mode.mode-donate { color: #2ED573; }
.item-mode.mode-help { color: #FFA502; }

/* 加载状态 */
.loading-state { text-align: center; padding: 40px 20px; }
.loading-icon { font-size: 24px; margin-bottom: 8px; }
.loading-text { font-size: 14px; color: #999; }
