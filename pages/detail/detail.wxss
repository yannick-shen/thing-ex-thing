page{background:#f7f8fa}
.container{min-height:100vh;padding-bottom:80px}
.swiper-wrapper{position:relative}
.img-swiper{width:100%;height:375px;background:#000;border-radius:16px 16px 0 0;overflow:hidden}
.swiper-img{width:100%;height:100%}
.img-indicator{position:absolute;bottom:16px;right:16px;background:rgba(0,0,0,0.6);color:#fff;padding:4px 12px;border-radius:12px;font-size:12px;z-index:10}
.info-card{background:#fff;padding:16px;margin-bottom:12px;border-radius:16px}
.title{font-size:18px;font-weight:600;margin-bottom:12px;color:#333}
.price-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.price{font-size:24px;color:#ff4d4f;font-weight:600}
.stats{display:flex;gap:16px;font-size:12px;color:#999}
.desc{font-size:14px;line-height:1.6;color:#666;margin-bottom:12px}
.meta{display:flex;flex-direction:column;gap:4px;font-size:12px;color:#999}
.location-card{background:#fff;padding:16px;margin-bottom:12px}
.card-title{font-size:14px;font-weight:600;margin-bottom:8px;color:#333}
.location-map{width:100%;height:180px;border-radius:8px;margin-bottom:8px}
.address{display:block;font-size:14px;color:#666;margin-bottom:8px}
.tip{font-size:12px;color:#999;line-height:1.4}
.actions{position:fixed;bottom:0;left:0;right:0;background:#fff;padding:8px 16px;display:flex;gap:8px;box-shadow:0 -2px 8px rgba(0,0,0,0.05);padding-bottom:env(safe-area-inset-bottom)}
.btn-fav{flex:1;background:#fff;color:#1677ff;border:1px solid #1677ff;border-radius:6px;font-size:15px;height:36px;display:flex;align-items:center;justify-content:center}
.btn-fav.favorited{background:#1677ff;color:#fff}
.btn-contact{flex:2;background:#1677ff;color:#fff;border-radius:6px;font-size:15px;height:36px;display:flex;align-items:center;justify-content:center}
.btn-unpublish{flex:1;background:#ff9800;color:#fff;border-radius:6px;font-size:15px;height:36px;display:flex;align-items:center;justify-content:center}
.btn-view-comments{flex:2;background:#1677ff;color:#fff;border-radius:6px;font-size:15px;height:36px;display:flex;align-items:center;justify-content:center}
.btn-hover{opacity:0.7;transform:scale(0.98)}
.loading{padding:40px;text-align:center;color:#999}
.report-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:1000;display:flex;align-items:center;justify-content:center}
.report-dialog{background:#fff;margin:0 32px;border-radius:12px;padding:20px;width:calc(100% - 64px);max-width:400px}
.report-title{font-size:16px;font-weight:600;margin-bottom:16px;text-align:center}
.report-reasons{margin-bottom:16px}
.reason-item{padding:12px;border:1px solid #e0e0e0;border-radius:8px;margin-bottom:8px;font-size:14px}
.reason-item.selected{border-color:#1677ff;background:#e6f7ff;color:#1677ff}
.report-detail{background:#f5f5f5;padding:12px;border-radius:8px;font-size:14px;width:100%;box-sizing:border-box;min-height:80px;margin-bottom:16px}
.report-actions{display:flex;gap:12px}
.btn-cancel{flex:1;background:#f5f5f5;color:#333;border-radius:8px;font-size:14px}
.btn-submit{flex:1;background:#1677ff;color:#fff;border-radius:8px;font-size:14px}
