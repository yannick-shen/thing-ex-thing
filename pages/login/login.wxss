.login-container {
  min-height: 100vh;
  background: white;
  display: flex;
  flex-direction: column;
}

/* 状态栏占位 */
.status-bar-placeholder {
  height: var(--status-bar-height, 44rpx);
}

/* 主要内容区域 */
.content-area {
  flex: 1;
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
  letter-spacing: 2rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #999;
  display: block;
  letter-spacing: 1rpx;
}

/* 授权区域 */
.auth-section {
  margin-bottom: 60rpx;
}

.auth-tips {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 50rpx;
}

.tips-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 30rpx;
  text-align: center;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tips-item {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.tips-icon {
  color: #52c41a;
  font-weight: bold;
  margin-right: 15rpx;
  font-size: 24rpx;
}

.tips-text {
  flex: 1;
}

/* 微信登录按钮 */
.wechat-login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
  transition: all 0.3s ease;
}

.wechat-login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.25);
}

.wechat-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.btn-text {
  font-size: 32rpx;
}

/* 协议文本 */
.agreement-text {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.agreement-text .link {
  color: #1890ff;
  text-decoration: underline;
}

/* 协议勾选区域 */
.agreement-check {
  margin: 40rpx 0 30rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.agreement-label {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.agreement-checkbox {
  margin-right: 12rpx;
  margin-top: 4rpx;
}

.agreement-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  flex: 1;
}

.agreement-links {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  padding-left: 32rpx;
}

.agreement-links .link {
  color: #1890ff;
  text-decoration: underline;
}

/* 禁用状态 */
.wechat-login-btn.disabled {
  background: #ccc !important;
  color: #999 !important;
  box-shadow: none !important;
}

.wechat-login-btn.disabled:active {
  transform: none !important;
}

/* 底部操作 */
.bottom-actions {
  padding: 20rpx 40rpx 40rpx;
  text-align: center;
}

.skip-btn {
  font-size: 28rpx;
  color: #666;
  padding: 20rpx 40rpx;
  background: #f8f9fa;
  border-radius: 40rpx;
  display: inline-block;
}