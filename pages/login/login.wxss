.login-container {
  min-height: 100vh;
  background: white;
  display: flex;
  flex-direction: column;
}

/* 状态栏占位 */
.status-bar-placeholder {
  height: var(--status-bar-height, 44rpx);
}

/* 主要内容区域 */
.content-area {
  flex: 1;
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
  letter-spacing: 2rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #999;
  display: block;
  letter-spacing: 1rpx;
}

/* 授权区域 */
.auth-section {
  margin-bottom: 60rpx;
}

.auth-tips {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 50rpx;
}

.tips-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 30rpx;
  text-align: center;
}

/* 权限说明 */
.auth-permission {
  margin: 40rpx 0;
}

.permission-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
}

.permission-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.permission-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  background: #f8f9fa;
  padding: 15rpx 20rpx;
  border-radius: 12rpx;
}

.permission-icon {
  margin-right: 12rpx;
  font-size: 20rpx;
}

.permission-text {
  flex: 1;
  line-height: 1.4;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tips-item {
  display: flex;
  align-items: center;
  padding-left: 150rpx;
  font-size: 28rpx;
  color: #666;
}

.tips-icon {
  color: #52c41a;
  font-weight: bold;
  margin-right: 15rpx;
  font-size: 24rpx;
}

.tips-text {
}

/* 微信登录按钮 */
.wechat-login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
  transition: all 0.3s ease;
}

.wechat-login-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.25);
}

.btn-text {
  font-size: 32rpx;
}

/* 协议文本 */
.agreement-text {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.agreement-text .link {
  color: #1890ff;
  text-decoration: underline;
}

/* 协议勾选区域 */
.agreement-check {
  margin: 40rpx 0 30rpx;
  padding: 0 80rpx;  /* 保持左右距离，整体宽松 */
  background: white;
}

.agreement-group {
  display: flex;
  flex-direction: row;
  align-items: center;  /* 垂直居中，确保同一行 */
  gap: 16rpx;  /* checkbox 和文字间距 */
}

.agreement-checkbox {
  margin: 0;
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.agreement-content {
  display: flex;
  flex-direction: row;
  align-items: center;
  white-space: nowrap;  /* 强制一行，不换行 */
  overflow: hidden;  /* 如果文字超长，隐藏溢出（小程序宽够用） */
  font-size: 24rpx;
  line-height: 1.5;
  color: #666;
  flex: 1;
  gap: 4rpx;
}

.agreement-text {
  color: #333;
}

.link {
  color: #1890ff;
}

/* 禁用状态 */
.wechat-login-btn.disabled {
  background: #ccc !important;
  color: #999 !important;
  box-shadow: none !important;
}

.wechat-login-btn.disabled:active {
  transform: none !important;
}

/* 底部操作 */
.bottom-actions {
  padding: 20rpx 40rpx 40rpx;
  text-align: center;
}

.skip-btn {
  font-size: 28rpx;
  color: #666;
  padding: 20rpx 40rpx;
  background: #f8f9fa;
  border-radius: 40rpx;
  display: inline-block;
}

/* 调试按钮样式 */
.debug-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background-color: #f8f9fa;
  color: #666;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid #ddd;
  margin-top: 20rpx;
  transition: all 0.3s ease;
}

.debug-btn:active {
  transform: scale(0.98);
  background-color: #e9ecef;
}