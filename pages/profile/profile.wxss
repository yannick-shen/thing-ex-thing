.profile-container {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

/* 顶部个人信息 */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx 60rpx;
  color: white;
}

/* 登录提示 */
.login-prompt {
  text-align: center;
  padding: 60rpx 40rpx;
}

.login-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.login-text {
  margin-bottom: 50rpx;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.login-desc {
  font-size: 26rpx;
  opacity: 0.8;
  line-height: 1.5;
}

.login-btn {
  background: rgba(255, 255, 255, 0.2);
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
  backdrop-filter: blur(10rpx);
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  margin-right: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  font-size: 60rpx;
}

.user-details {
  flex: 1;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 统计信息 */
.stats {
  display: flex;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 30rpx;
  backdrop-filter: blur(10rpx);
}

.stat-item {
  flex: 1;
  text-align: center;
  cursor: pointer;
}

.stat-number {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 功能菜单 */
.menu-section {
  padding: 20rpx 30rpx;
}

.menu-group {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 25rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
}

.menu-info {
  flex: 1;
}

.menu-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 5rpx;
}

.menu-desc {
  font-size: 26rpx;
  color: #666;
}

.menu-badge {
  background: #ff4757;
  color: white;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 30rpx;
  text-align: center;
  margin-right: 15rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 退出登录按钮 */
.logout-item {
  background: #fff5f5;
  border-bottom: 1rpx solid #ffedeb;
}

.logout-item:active {
  background: #ffe8e6;
}

.logout-title {
  color: #ff4d4f;
  font-weight: bold;
}

.logout-desc {
  color: #ff7875;
  font-size: 24rpx;
}

