.profile-container {
  min-height: 94vh;
  background: white;
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
}

/* 顶部个人信息 */
.header {
  background: white;
  padding: 10rpx 30rpx 0rpx;
  color: white;
}

/* 登录提示 */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 60rpx;
  padding-bottom: 30rpx;
}

.login-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  opacity: 0.5;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 60rpx;
}

.login-btn {
  background: #1677ff;
  color: white;
  border: none;
  border-radius: 8px;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: bold;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  margin-right: 30rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  font-size: 60rpx;
}

.avatar-edit-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  font-size: 20rpx;
  padding: 6rpx 0;
  text-align: center;
  border-bottom-left-radius: 60rpx;
  border-bottom-right-radius: 60rpx;
}

.user-details {
  flex: 1;
}

.username {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.edit-icon {
  font-size: 20rpx;
  margin-left: 20rpx;
}

/* 功能菜单 */
.menu-section {
  padding: 10rpx 30rpx 10rpx;
}

.menu-group {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 25rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
}

.menu-info {
  flex: 1;
}

.menu-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 5rpx;
}

.menu-desc {
  font-size: 26rpx;
  color: #666;
}

.menu-badge {
  background: #ff4757;
  color: white;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 30rpx;
  text-align: center;
  margin-right: 15rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 退出登录按钮 */
.logout-item {
  background: #fff5f5;
  border-bottom: 1rpx solid #ffedeb;
}

.logout-item:active {
  background: #ffe8e6;
}

.logout-title {
  color: #ff4d4f;
  font-weight: bold;
}

.logout-desc {
  color: #ff7875;
  font-size: 24rpx;
}

