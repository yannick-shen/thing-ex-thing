page { background: #f7f8fa; }
.search-capsule { position: fixed; top: 12px; left: 16px; right: 16px; z-index: 9; }
.capsule { background: rgba(255,255,255,0.9); border-radius: 24px; height: 36px; display: flex; align-items: center; padding: 0 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
.capsule-text { color: #8c8c8c; font-size: 14px; }
.filter-tag { position: fixed; top: 56px; right: 16px; z-index: 9; background: rgba(0,0,0,0.6); color: #fff; padding: 4px 8px; border-radius: 12px; font-size: 12px; }
.overlay { position: fixed; left: 0; top: 0; right: 0; bottom: 0; z-index: 99; background: rgba(0,0,0,0.5); display: flex; align-items: flex-start; justify-content: center; }
.search-panel { margin-top: 60px; width: 92%; background: #fff; border-radius: 12px; padding: 12px; }
.search-input { background: #f5f5f5; border-radius: 8px; padding: 8px 10px; font-size: 14px; }
.search-actions { margin-top: 10px; display: flex; justify-content: flex-end; gap: 12px; }
.btn { background: #1677ff; color: #fff; padding: 8px 12px; border-radius: 6px; }
.btn.secondary { background: #e6e6e6; color: #333; }