page { background: #f7f8fa; }

/* ========== 基础样式规范 ========== */

/* 文本层级 */
.text-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.text-body {
  font-size: 14px;
  color: #666;
}

.text-muted {
  font-size: 12px;
  color: #999;
}

.text-small {
  font-size: 12px;
  color: #666;
}

.text-danger {
  font-size: 14px;
  color: #ff4d4f;
}

/* 卡片容器 */
.card {
  background: #fff;
  border-radius: 12px;
  padding: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.card-item {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

.card-item:last-child {
  border-bottom: none;
}

/* 按钮基础样式 */
.btn-primary {
  background: #1677ff;
  color: #fff;
  padding: 10px 20px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #e6e6e6;
  color: #333;
  padding: 10px 20px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
}

.btn-secondary::after {
  border: none;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
  padding: 10px 20px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
}

.btn-danger::after {
  border: none;
}

.btn-small {
  padding: 6px 12px;
  border-radius: 6px;
  font-size: 12px;
}

/* 输入框基础样式 */
.input {
  background: #f5f5f5;
  border-radius: 8px;
  padding: 10px 12px;
  font-size: 14px;
  color: #333;
}

.input-placeholder {
  color: #999;
}

/* 通用工具类 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.gap-sm {
  gap: 8px;
}

.gap-md {
  gap: 12px;
}

.gap-lg {
  gap: 16px;
}