/* 遮罩层 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  animation: fadeIn 0.3s ease-out;
}

/* 弹窗内容 */
.modal-content {
  width: 85%;
  max-width: 600rpx;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  animation: slideUp 0.3s ease-out;
}

/* 弹窗头部 */
.modal-header {
  text-align: center;
  padding: 60rpx 40rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.modal-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
}

/* 弹窗主体 */
.modal-body {
  padding: 40rpx;
}

.modal-text {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

.feature-list {
  margin-top: 30rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.feature-icon {
  color: #667eea;
  font-weight: bold;
  margin-right: 15rpx;
  font-size: 28rpx;
}

/* 弹窗底部 */
.modal-footer {
  padding: 20rpx 40rpx 40rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ae56 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.login-btn:active {
  transform: scale(0.98);
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

